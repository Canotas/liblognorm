prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: lognorm
Description: fast samples-based log normalization library
Version: @VERSION@
Requires: libfastjson libestr
Libs: -L${libdir} -llognorm
Libs.private: @LIBXML2_LIBS@ @JSON_C_LIBS@ @PCRE_LIBS@
Cflags: -I${includedir}
